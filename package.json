{
  "name": "@link-foundation/example-package-name",
  "version": "0.11.3",
  "description": "A JavaScript/TypeScript package template for AI-driven development",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "example-package-name": "./bin/example-package-name.js"
  },
  "files": [
    "bin/",
    "src/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "scripts": {
    "test": "node --test --test-timeout=30000 tests/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:duplication": "jscpd .",
    "check": "npm run lint && npm run format:check && npm run check:duplication",
    "example:web:dev": "npm --prefix examples/universal-app run dev",
    "example:web:build": "npm --prefix examples/universal-app run build",
    "example:web:preview": "npm --prefix examples/universal-app run preview",
    "example:web:preview-images": "node scripts/update-preview-images.mjs",
    "example:desktop:package": "npm --prefix examples/universal-app run desktop:package",
    "example:desktop:make": "npm --prefix examples/universal-app run desktop:make",
    "example:mobile:sync": "npm --prefix examples/universal-app run mobile:sync",
    "prepare": "husky || true",
    "changeset": "changeset",
    "changeset:version": "node scripts/changeset-version.mjs",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status --since=origin/main"
  },
  "keywords": [
    "template",
    "javascript",
    "typescript",
    "ai-driven"
  ],
  "author": "",
  "license": "Unlicense",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/link-foundation/js-ai-driven-development-pipeline-template.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "test-anywhere": "^0.8.48"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write",
      "prettier --check"
    ],
    "*.md": [
      "prettier --write",
      "prettier --check"
    ]
  }
}
