@@ -0,0 +1,1357 @@
+name: JavaScript CI/CD
+
+on:
+  push:
+    branches:
+      - main
+    tags:
+      - 'v*.*.*'
+  pull_request:
+    types: [opened, synchronize, reopened]
+  workflow_dispatch:
+    inputs:
+      release_mode:
+        description: 'Manual release mode'
+        required: true
+        type: choice
+        default: 'checks'
+        options:
+          - checks
+          - instant
+          - changeset-pr
+          - desktop-artifacts
+      bump_type:
+        description: 'Manual release type'
+        required: false
+        type: choice
+        default: patch
+        options:
+          - patch
+          - minor
+          - major
+      description:
+        description: 'Manual release description (optional)'
+        required: false
+        type: string
+      tag:
+        description: 'Desktop release tag for desktop-artifacts mode (e.g. v0.9.10)'
+        required: false
+        type: string
+      target_sha:
+        description: 'Commit SHA to build for desktop-artifacts mode'
+        required: false
+        type: string
+
+permissions:
+  contents: read
+
+# Concurrency: Only one workflow run per branch at a time
+# - For main branch (releases): cancel older runs to prevent blocking newer releases
+#   When multiple commits are pushed quickly, we want the latest to release, not wait
+# - For PR branches: queue runs to avoid cancelling checks on force-pushes
+# See: docs/case-studies/issue-25/DETAILED-COMPARISON.md for context
+concurrency:
+  group: ${{ github.workflow }}-${{ github.ref }}
+  cancel-in-progress: ${{ github.ref == 'refs/heads/main' }}
+
+jobs:
+  # === DETECT CHANGES - determines which jobs should run ===
+  detect-changes:
+    name: Detect Changes
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+    if: github.event_name != 'workflow_dispatch' && !startsWith(github.ref, 'refs/tags/')
+    outputs:
+      mjs-changed: ${{ steps.changes.outputs.mjs-changed }}
+      js-changed: ${{ steps.changes.outputs.js-changed }}
+      package-changed: ${{ steps.changes.outputs.package-changed }}
+      docs-changed: ${{ steps.changes.outputs.docs-changed }}
+      html-changed: ${{ steps.changes.outputs.html-changed }}
+      site-changed: ${{ steps.changes.outputs.site-changed }}
+      pages-changed: ${{ steps.changes.outputs.pages-changed }}
+      links-changed: ${{ steps.changes.outputs.links-changed }}
+      workflow-changed: ${{ steps.changes.outputs.workflow-changed }}
+      any-code-changed: ${{ steps.changes.outputs.any-code-changed }}
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Detect changes
+        id: changes
+        run: node scripts/detect-code-changes.mjs
+
+  # === FAST CHECKS - run before slow tests for fastest feedback ===
+  # See: hive-mind CI/CD best practices principle #5 (fast-fail job ordering)
+
+  # Syntax check all .mjs files with node --check (~7s)
+  test-compilation:
+    name: Test Compilation
+    runs-on: ubuntu-latest
+    # Typical run: <10s. Tight cap fails fast on syntax-check hangs.
+    timeout-minutes: 5
+    needs: [detect-changes]
+    if: |
+      !startsWith(github.ref, 'refs/tags/') &&
+      (github.event_name == 'push' ||
+      needs.detect-changes.outputs.mjs-changed == 'true' ||
+      needs.detect-changes.outputs.js-changed == 'true')
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Check .mjs syntax
+        run: bash scripts/check-mjs-syntax.sh
+
+  # Enforce 1500-line limit on .mjs files and js.yml
+  check-file-line-limits:
+    name: Check File Line Limits
+    runs-on: ubuntu-latest
+    # Typical run: <10s. This job only walks tracked files and counts lines.
+    timeout-minutes: 5
+    needs: [detect-changes]
+    if: |
+      !startsWith(github.ref, 'refs/tags/') &&
+      (github.event_name == 'push' ||
+      needs.detect-changes.outputs.mjs-changed == 'true' ||
+      needs.detect-changes.outputs.js-changed == 'true' ||
+      needs.detect-changes.outputs.workflow-changed == 'true')
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Simulate fresh merge with base branch (PR only)
+        if: github.event_name == 'pull_request'
+        env:
+          BASE_REF: ${{ github.base_ref }}
+        run: bash scripts/simulate-fresh-merge.sh
+
+      - name: Check file line limits
+        run: bash scripts/check-file-line-limits.sh
+
+  # === VERSION CHANGE CHECK ===
+  # Prohibit manual version changes in package.json - versions should only be changed by CI/CD
+  version-check:
+    name: Check for Manual Version Changes
+    runs-on: ubuntu-latest
+    # Typical run: ~6s. Read-only package.json diff inspection.
+    timeout-minutes: 5
+    if: github.event_name == 'pull_request'
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Check for version changes in package.json
+        env:
+          GITHUB_HEAD_REF: ${{ github.head_ref }}
+          GITHUB_BASE_REF: ${{ github.base_ref }}
+        run: node scripts/check-version.mjs
+
+  # === CHANGESET CHECK - only runs on PRs with code changes ===
+  # Docs-only PRs (./docs folder, markdown files) don't require changesets
+  changeset-check:
+    name: Check for Changesets
+    runs-on: ubuntu-latest
+    # Typical run: <30s including npm install. 10min covers cold runners.
+    timeout-minutes: 10
+    needs: [detect-changes]
+    if: github.event_name == 'pull_request' && needs.detect-changes.outputs.any-code-changed == 'true'
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install
+
+      - name: Check for changesets
+        env:
+          # Pass PR context to the validation script
+          GITHUB_BASE_REF: ${{ github.base_ref }}
+          GITHUB_BASE_SHA: ${{ github.event.pull_request.base.sha }}
+          GITHUB_HEAD_SHA: ${{ github.event.pull_request.head.sha }}
+        run: |
+          # Skip changeset check for automated version PRs
+          if [[ "${{ github.head_ref }}" == "changeset-release/"* ]]; then
+            echo "Skipping changeset check for automated release PR"
+            exit 0
+          fi
+
+          # Run changeset validation script
+          # This validates that exactly ONE changeset was ADDED by this PR
+          # Pre-existing changesets from other merged PRs are ignored
+          node scripts/validate-changeset.mjs
+
+  # === LINT AND FORMAT CHECK ===
+  # Lint runs independently of changeset-check - it's a fast check that should always run
+  # See: https://github.com/link-assistant/hive-mind/pull/1024 for why this dependency was removed
+  # IMPORTANT: ESLint includes max-lines rule (1500 lines) to ensure files stay maintainable
+  # See docs/case-studies/issue-23 for why fresh merge simulation is critical
+  lint:
+    name: Lint and Format Check
+    runs-on: ubuntu-latest
+    # Typical run: <1min including install, ESLint, Prettier, jscpd,
+    # and secretlint. 10min protects against a hung lint plugin.
+    timeout-minutes: 10
+    needs: [detect-changes]
+    if: |
+      !startsWith(github.ref, 'refs/tags/') &&
+      (github.event_name == 'push' ||
+      needs.detect-changes.outputs.mjs-changed == 'true' ||
+      needs.detect-changes.outputs.js-changed == 'true' ||
+      needs.detect-changes.outputs.docs-changed == 'true' ||
+      needs.detect-changes.outputs.package-changed == 'true' ||
+      needs.detect-changes.outputs.workflow-changed == 'true')
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          # For PRs, fetch enough history to merge with base branch
+          fetch-depth: 0
+
+      - name: Simulate fresh merge with base branch (PR only)
+        if: github.event_name == 'pull_request'
+        env:
+          BASE_REF: ${{ github.base_ref }}
+        run: bash scripts/simulate-fresh-merge.sh
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install
+
+      - name: Run ESLint
+        run: npm run lint
+
+      - name: Check formatting
+        run: npm run format:check
+
+      - name: Check code duplication
+        run: npm run check:duplication
+
+      - name: Check for secrets
+        run: npx --yes -p secretlint -p @secretlint/secretlint-rule-preset-recommend secretlint "**/*"
+
+  # Test matrix: 3 runtimes (Node.js, Bun, Deno) x 3 OS (Ubuntu, macOS, Windows)
+  # IMPORTANT: Tests must validate the ACTUAL merge result, not a stale merge preview.
+  # See docs/case-studies/issue-23 for why this is critical.
+  # Fast-fail: slow test matrix only runs after fast checks pass (hive-mind principle #5)
+  test:
+    name: Test (${{ matrix.runtime }} on ${{ matrix.os }})
+    runs-on: ${{ matrix.os }}
+    # Typical run: <1min per runtime/OS on warm runners, with Windows
+    # sometimes slower on cold starts. 10min fails hung tests well
+    # before GitHub Actions' 6h default.
+    timeout-minutes: 10
+    needs:
+      [
+        detect-changes,
+        changeset-check,
+        test-compilation,
+        lint,
+        check-file-line-limits,
+      ]
+    # Use !cancelled() instead of always() so cancellation propagates correctly (hive-mind issue #1278)
+    # Run if: push event, OR changeset-check succeeded, OR changeset-check was skipped (docs-only PR)
+    # AND all fast checks passed (or were skipped for irrelevant changes)
+    if: |
+      !cancelled() &&
+      !startsWith(github.ref, 'refs/tags/') &&
+      (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&
+      (needs.test-compilation.result == 'success' || needs.test-compilation.result == 'skipped') &&
+      (needs.lint.result == 'success' || needs.lint.result == 'skipped') &&
+      (needs.check-file-line-limits.result == 'success' || needs.check-file-line-limits.result == 'skipped')
+    strategy:
+      fail-fast: false
+      matrix:
+        os: [ubuntu-latest, macos-latest, windows-latest]
+        runtime: [node, bun, deno]
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          # For PRs, fetch enough history to merge with base branch
+          fetch-depth: 0
+
+      - name: Simulate fresh merge with base branch (PR only)
+        if: github.event_name == 'pull_request'
+        env:
+          BASE_REF: ${{ github.base_ref }}
+        shell: bash
+        run: bash scripts/simulate-fresh-merge.sh
+
+      - name: Setup Node.js
+        if: matrix.runtime == 'node'
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies (Node.js)
+        if: matrix.runtime == 'node'
+        run: npm install
+
+      - name: Run tests (Node.js)
+        if: matrix.runtime == 'node'
+        run: npm test
+
+      - name: Setup Bun
+        if: matrix.runtime == 'bun'
+        uses: oven-sh/setup-bun@v2
+        with:
+          bun-version: latest
+
+      - name: Install dependencies (Bun)
+        if: matrix.runtime == 'bun'
+        run: bun install
+
+      - name: Run tests (Bun)
+        if: matrix.runtime == 'bun'
+        # --timeout caps an individual test at 30s, matching Node's
+        # --test-timeout budget while leaving headroom for cold runners.
+        run: bun test --timeout 30000
+
+      - name: Setup Deno
+        if: matrix.runtime == 'deno'
+        uses: denoland/setup-deno@v2
+        with:
+          deno-version: v2.x
+
+      - name: Run tests (Deno)
+        if: matrix.runtime == 'deno'
+        run: deno test --allow-read
+
+  # === DOCUMENTATION VALIDATION ===
+  # Validate documentation files when docs change (hive-mind principle #12)
+  validate-docs:
+    name: Validate Documentation
+    runs-on: ubuntu-latest
+    # Typical run: <10s. Pure shell checks over documentation files.
+    timeout-minutes: 5
+    needs: [detect-changes]
+    if: |
+      !startsWith(github.ref, 'refs/tags/') &&
+      (github.event_name == 'push' ||
+      needs.detect-changes.outputs.docs-changed == 'true')
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Check documentation file sizes
+        run: |
+          LIMIT=2500
+          FAILURES=()
+
+          echo "Checking that documentation files are under ${LIMIT} lines..."
+
+          while IFS= read -r -d '' file; do
+            line_count=$(wc -l < "$file")
+            if [ "$line_count" -gt "$LIMIT" ]; then
+              echo "ERROR: $file has $line_count lines (limit: ${LIMIT})"
+              echo "::error file=$file::Documentation file has $line_count lines (limit: ${LIMIT})"
+              FAILURES+=("$file")
+            fi
+          done < <(find docs -name "*.md" -type f -print0 2>/dev/null)
+
+          if [ "${#FAILURES[@]}" -gt 0 ]; then
+            echo "The following docs exceed the ${LIMIT} line limit:"
+            printf '  %s\n' "${FAILURES[@]}"
+            exit 1
+          else
+            echo "All documentation files are within the ${LIMIT} line limit."
+          fi
+
+      - name: Check required documentation files exist
+        run: |
+          REQUIRED_FILES=(
+            "docs/BEST-PRACTICES.md"
+            "docs/CONTRIBUTING.md"
+            "docs/REQUIREMENTS.md"
+            "README.md"
+            "CHANGELOG.md"
+          )
+
+          MISSING=()
+          for file in "${REQUIRED_FILES[@]}"; do
+            if [ ! -f "$file" ]; then
+              echo "ERROR: Required documentation file missing: $file"
+              MISSING+=("$file")
+            else
+              echo "Found: $file"
+            fi
+          done
+
+          if [ "${#MISSING[@]}" -gt 0 ]; then
+            echo ""
+            echo "Missing required documentation files:"
+            printf '  %s\n' "${MISSING[@]}"
+            exit 1
+          else
+            echo "All required documentation files present."
+          fi
+
+  # Release - only runs on main after tests pass (for push events)
+  release:
+    name: Release
+    needs: [lint, test]
+    # Includes versioning and same-workflow desktop release publication.
+    timeout-minutes: 90
+    # Use !cancelled() instead of always() so cancellation propagates correctly (hive-mind issue #1278)
+    # This is needed because lint/test jobs have a transitive dependency on changeset-check
+    if: |
+      !cancelled() &&
+      github.ref == 'refs/heads/main' &&
+      github.event_name == 'push' &&
+      needs.lint.result == 'success' &&
+      needs.test.result == 'success'
+    runs-on: ubuntu-latest
+    outputs:
+      release-tag: ${{ steps.release_version.outputs.tag }}
+      release-version: ${{ steps.release_version.outputs.version }}
+      target-sha: ${{ steps.release_target.outputs.sha }}
+    # Permissions required to version main and create release state.
+    permissions:
+      contents: write
+      pull-requests: write
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install
+
+      - name: Check for changesets
+        id: check_changesets
+        run: node scripts/check-changesets.mjs
+
+      - name: Check if release is needed
+        id: check_release
+        env:
+          HAS_CHANGESETS: ${{ steps.check_changesets.outputs.has_changesets }}
+          REPOSITORY: ${{ github.repository }}
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+        run: node scripts/check-release-needed.mjs
+
+      - name: Merge multiple changesets
+        if: steps.check_changesets.outputs.has_changesets == 'true' && steps.check_changesets.outputs.changeset_count > 1
+        run: |
+          echo "Multiple changesets detected, merging..."
+          node scripts/merge-changesets.mjs
+
+      - name: Version packages and commit to main
+        if: steps.check_changesets.outputs.has_changesets == 'true'
+        id: version
+        run: node scripts/version-and-commit.mjs --mode changeset
+
+      - name: Determine release version
+        id: release_version
+        if: >-
+          steps.version.outputs.version_committed == 'true' ||
+          steps.version.outputs.already_released == 'true' ||
+          (steps.check_release.outputs.should_release == 'true' && steps.check_release.outputs.skip_bump == 'true')
+        run: |
+          VERSION="${{ steps.version.outputs.new_version }}"
+          if [ -z "$VERSION" ]; then
+            VERSION="$(node -p "JSON.parse(require('node:fs').readFileSync('package.json', 'utf8')).version")"
+          fi
+
+          echo "version=$VERSION" >> "$GITHUB_OUTPUT"
+          echo "tag=v$VERSION" >> "$GITHUB_OUTPUT"
+
+      - name: Resolve release target commit
+        id: release_target
+        if: >-
+          steps.version.outputs.version_committed == 'true' ||
+          steps.version.outputs.already_released == 'true' ||
+          (steps.check_release.outputs.should_release == 'true' && steps.check_release.outputs.skip_bump == 'true')
+        run: |
+          git fetch origin main
+          SHA="$(git rev-parse origin/main)"
+          echo "sha=$SHA" >> "$GITHUB_OUTPUT"
+
+  # Manual Instant Release - triggered via workflow_dispatch with instant mode
+  # This job versions main, then hands the exact tag and SHA to desktop jobs.
+  instant-release:
+    name: Instant Release
+    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'instant'
+    runs-on: ubuntu-latest
+    # Same release envelope as the automated release path.
+    timeout-minutes: 90
+    outputs:
+      release-tag: ${{ steps.release_version.outputs.tag }}
+      release-version: ${{ steps.release_version.outputs.version }}
+      target-sha: ${{ steps.release_target.outputs.sha }}
+    # Permissions required to version main and create release state.
+    permissions:
+      contents: write
+      pull-requests: write
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install
+
+      - name: Version packages and commit to main
+        id: version
+        run: node scripts/version-and-commit.mjs --mode instant --bump-type "${{ github.event.inputs.bump_type }}" --description "${{ github.event.inputs.description }}"
+
+      - name: Determine release version
+        id: release_version
+        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'
+        run: |
+          VERSION="${{ steps.version.outputs.new_version }}"
+          if [ -z "$VERSION" ]; then
+            VERSION="$(node -p "JSON.parse(require('node:fs').readFileSync('package.json', 'utf8')).version")"
+          fi
+
+          echo "version=$VERSION" >> "$GITHUB_OUTPUT"
+          echo "tag=v$VERSION" >> "$GITHUB_OUTPUT"
+
+      - name: Resolve release target commit
+        id: release_target
+        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'
+        run: |
+          git fetch origin main
+          SHA="$(git rev-parse origin/main)"
+          echo "sha=$SHA" >> "$GITHUB_OUTPUT"
+
+  # Manual Changeset PR - creates a pull request with the changeset for review
+  changeset-pr:
+    name: Create Changeset PR
+    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'changeset-pr'
+    runs-on: ubuntu-latest
+    # PR creation only: install, create a changeset, format, and open a PR.
+    timeout-minutes: 10
+    permissions:
+      contents: write
+      pull-requests: write
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install
+
+      - name: Create changeset file
+        run: node scripts/create-manual-changeset.mjs --bump-type "${{ github.event.inputs.bump_type }}" --description "${{ github.event.inputs.description }}"
+
+      - name: Format changeset with Prettier
+        run: |
+          # Run Prettier on the changeset file to ensure it matches project style
+          npx prettier --write ".changeset/*.md" || true
+
+          echo "Formatted changeset files"
+
+      - name: Create Pull Request
+        uses: peter-evans/create-pull-request@v8
+        with:
+          token: ${{ secrets.GITHUB_TOKEN }}
+          commit-message: 'chore: add changeset for manual ${{ github.event.inputs.bump_type }} release'
+          branch: changeset-manual-release-${{ github.run_id }}
+          delete-branch: true
+          title: 'chore: manual ${{ github.event.inputs.bump_type }} release'
+          body: |
+            ## Manual Release Request
+
+            This PR was created by a manual workflow trigger to prepare a **${{ github.event.inputs.bump_type }}** release.
+
+            ### Release Details
+            - **Type:** ${{ github.event.inputs.bump_type }}
+            - **Description:** ${{ github.event.inputs.description || 'Manual release' }}
+            - **Triggered by:** @${{ github.actor }}
+
+            ### Next Steps
+            1. Review the changeset in this PR
+            2. Merge this PR to main
+            3. The automated release workflow will create a version PR
+            4. Merge the version PR to build desktop artifacts and publish GitHub Release assets from this workflow
+
+  link-checker:
+    name: Check Links
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    needs: [detect-changes]
+    if: |
+      always() &&
+      !cancelled() &&
+      !startsWith(github.ref, 'refs/tags/') &&
+      ((github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'checks') ||
+      needs.detect-changes.outputs.links-changed == 'true')
+    permissions:
+      contents: read
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Check links with lychee
+        id: lychee
+        uses: lycheeverse/lychee-action@v2
+        with:
+          args: >-
+            --verbose
+            --no-progress
+            --cache
+            --max-cache-age 1d
+            --max-retries 3
+            --timeout 30
+            --exclude-path docs/case-studies
+            './**/*.md'
+            './**/*.html'
+          fail: false
+          output: lychee/out.md
+          jobSummary: true
+        env:
+          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Check broken links against Web Archive
+        if: steps.lychee.outputs.exit_code != 0
+        id: webarchive
+        run: node scripts/check-web-archive.mjs
+        env:
+          LYCHEE_OUTPUT: lychee/out.md
+
+      - name: Fail if broken links found and no web archive fallback
+        if: steps.lychee.outputs.exit_code != 0 && steps.webarchive.outputs.all_archived != 'true'
+        run: |
+          echo "::error::Broken links were detected with no Web Archive fallback available."
+          echo ""
+          echo "What happened:"
+          echo "  lychee found one or more broken links in the *.md and *.html files of this repository."
+          echo "  The Web Archive (Wayback Machine) check found no archived versions for some of them."
+          echo ""
+          echo "How to fix:"
+          echo "  1. Review the 'Check links with lychee' step above for a full list of broken links."
+          echo "  2. For links marked with a '::notice::' annotation above, a Web Archive version exists."
+          echo "     Replace those broken links with the suggested archive.org URL."
+          echo "  3. For links with no archive version, either:"
+          echo "     a. Find an updated URL that points to the same or equivalent content."
+          echo "     b. Remove the link if the content is no longer relevant."
+          echo "     c. Add the URL to .lycheeignore if it is a known false positive."
+          echo ""
+          echo "Report location: lychee/out.md (available as a workflow artifact if configured)."
+          exit 1
+
+  pages-build:
+    name: Build Pages site
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    needs: [detect-changes]
+    # Build whenever the deploy must run, plus on PRs that touch
+    # site/build files so PR feedback stays fast.
+    # Main pushes and release tags must always rebuild so the deployed
+    # download page reflects the latest Release API data (see issue #28
+    # and REQUIREMENTS Release And Distribution #19, #26).
+    if: |
+      always() &&
+      !cancelled() &&
+      ((github.event_name == 'push' && github.ref == 'refs/heads/main') ||
+      (github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')) ||
+      (github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'checks') ||
+      (github.event_name == 'pull_request' && needs.detect-changes.outputs.pages-changed == 'true'))
+    permissions:
+      contents: read
+      pages: write
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Install dependencies
+        run: npm install --no-audit --no-fund
+
+      - name: Build site
+        run: npm run build:site
+
+      - name: Install browser e2e dependencies
+        env:
+          PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD: '1'
+        run: npm install --no-save --package-lock=false --no-audit --no-fund browser-commander@0.8.0 playwright@1.59.1
+
+      - name: Install Chromium for browser e2e tests
+        run: npx playwright install chromium
+
+      - name: Test built Pages site before deploy
+        run: npm run test:pages:e2e -- --site-dir site/dist
+
+      - name: Configure GitHub Pages
+        if: github.event_name == 'push' && (github.ref == 'refs/heads/main' || startsWith(github.ref, 'refs/tags/v'))
+        uses: actions/configure-pages@v5
+        with:
+          enablement: true
+
+      - name: Upload GitHub Pages artifact
+        if: github.event_name == 'push' && (github.ref == 'refs/heads/main' || startsWith(github.ref, 'refs/tags/v'))
+        uses: actions/upload-pages-artifact@v4
+        with:
+          path: site/dist
+
+  pages-deploy:
+    name: Deploy Pages site
+    # Deploy on every main push and on every release tag push, so the
+    # download page never stays stale relative to GitHub Releases.
+    if: github.event_name == 'push' && (github.ref == 'refs/heads/main' || startsWith(github.ref, 'refs/tags/v'))
+    needs: [pages-build]
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    permissions:
+      contents: read
+      pages: write
+      id-token: write
+    environment:
+      name: github-pages
+      url: ${{ steps.deployment.outputs.page_url }}
+    steps:
+      - uses: actions/checkout@v6
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v6
+        with:
+          node-version: '24.x'
+
+      - name: Deploy to GitHub Pages
+        id: deployment
+        uses: actions/deploy-pages@v4
+
+      - name: Install browser e2e dependencies
+        env:
+          PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD: '1'
+        run: npm install --no-save --package-lock=false --no-audit --no-fund browser-commander@0.8.0 playwright@1.59.1
+
+      - name: Install Chromium for browser e2e tests
+        run: npx playwright install chromium
+
+      - name: Test published Pages site after deploy
+        # Pass GITHUB_TOKEN so the GitHub Release API call inside the e2e
+        # script runs authenticated. Unauthenticated requests share a 60/hr
+        # IP-pool rate limit on hosted runners; authenticated requests get
+        # the per-token 5000/hr limit. Without this env, the post-deploy
+        # smoke test fails with `Release request failed: 403` (issue #28
+        # follow-up; run 25668347176).
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+        run: npm run test:pages:e2e -- --url "${{ steps.deployment.outputs.page_url }}"
+
+  desktop-release-context:
+    name: Resolve desktop release context
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+    needs: [release, instant-release]
+    if: |
+      always() &&
+      !cancelled() &&
+      (startsWith(github.ref, 'refs/tags/v') ||
+      needs.release.outputs.release-tag != '' ||
+      needs.instant-release.outputs.release-tag != '' ||
+      (github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'desktop-artifacts'))
+    outputs:
+      release-tag: ${{ steps.context.outputs.release-tag }}
+      release-version: ${{ steps.context.outputs.release-version }}
+      target-sha: ${{ steps.context.outputs.target-sha }}
+      should-publish: ${{ steps.context.outputs.should-publish }}
+    steps:
+      - name: Resolve release tag and target SHA
+        id: context
+        shell: bash
+        env:
+          AUTOMATIC_TAG: ${{ needs.release.outputs.release-tag }}
+          AUTOMATIC_SHA: ${{ needs.release.outputs.target-sha }}
+          INSTANT_TAG: ${{ needs.instant-release.outputs.release-tag }}
+          INSTANT_SHA: ${{ needs.instant-release.outputs.target-sha }}
+          MANUAL_TAG: ${{ github.event.inputs.tag }}
+          MANUAL_TARGET_SHA: ${{ github.event.inputs.target_sha }}
+        run: |
+          set -euo pipefail
+
+          TAG=""
+          TARGET_SHA=""
+
+          if [[ "$GITHUB_REF" == refs/tags/v* ]]; then
+            TAG="$GITHUB_REF_NAME"
+            TARGET_SHA="$GITHUB_SHA"
+          elif [ -n "$AUTOMATIC_TAG" ]; then
+            TAG="$AUTOMATIC_TAG"
+            TARGET_SHA="$AUTOMATIC_SHA"
+          elif [ -n "$INSTANT_TAG" ]; then
+            TAG="$INSTANT_TAG"
+            TARGET_SHA="$INSTANT_SHA"
+          else
+            TAG="$MANUAL_TAG"
+            TARGET_SHA="$MANUAL_TARGET_SHA"
+            if [ -z "$TARGET_SHA" ]; then
+              TARGET_SHA="$GITHUB_SHA"
+            fi
+          fi
+
+          if [[ ! "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$ ]]; then
+            echo "::error::Desktop release tag must look like v0.9.10. Got: $TAG"
+            exit 1
+          fi
+
+          if [ -z "$TARGET_SHA" ]; then
+            echo "::error::Desktop release target SHA is empty for $TAG."
+            exit 1
+          fi
+
+          echo "release-tag=$TAG" >> "$GITHUB_OUTPUT"
+          echo "release-version=${TAG#v}" >> "$GITHUB_OUTPUT"
+          echo "target-sha=$TARGET_SHA" >> "$GITHUB_OUTPUT"
+          echo "should-publish=true" >> "$GITHUB_OUTPUT"
+
+  desktop-build:
+    name: Build desktop (${{ matrix.platform }} ${{ matrix.arch }})
+    needs: [desktop-release-context]
+    if: |
+      always() &&
+      !cancelled() &&
+      needs.desktop-release-context.result == 'success' &&
+      needs.desktop-release-context.outputs.should-publish == 'true'
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          - os: ubuntu-latest
+            platform: linux
+            arch: x64
+          - os: ubuntu-24.04-arm
+            platform: linux
+            arch: arm64
+          - os: macos-latest
+            platform: macos
+            arch: x64-arm64
+          - os: windows-latest
+            platform: windows
+            arch: x64
+          - os: windows-11-arm
+            platform: windows
+            arch: arm64
+    runs-on: ${{ matrix.os }}
+    timeout-minutes: 45
+    permissions:
+      contents: read
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          ref: ${{ needs.desktop-release-context.outputs.target-sha }}
+
+      - uses: actions/setup-node@v6
+        with:
+          node-version: '20.x'
+
+      - name: Install dependencies
+        run: npm install --no-audit --no-fund
+
+      - name: Build renderer bundle
+        run: npm run build:renderer
+
+      - name: Install system FPM (Linux arm64)
+        if: matrix.platform == 'linux' && matrix.arch == 'arm64'
+        run: |
+          sudo apt-get update
+          sudo apt-get install -y ruby ruby-dev build-essential
+          sudo gem install --no-document fpm
+
+      - name: Check macOS signing secrets
+        id: mac_secrets
+        if: matrix.platform == 'macos'
+        shell: bash
+        env:
+          MAC_CSC_LINK: ${{ secrets.MAC_CSC_LINK }}
+          MAC_CSC_KEY_PASSWORD: ${{ secrets.MAC_CSC_KEY_PASSWORD }}
+          APPLE_API_KEY: ${{ secrets.APPLE_API_KEY }}
+          APPLE_API_KEY_ID: ${{ secrets.APPLE_API_KEY_ID }}
+          APPLE_API_ISSUER: ${{ secrets.APPLE_API_ISSUER }}
+        run: |
+          set -euo pipefail
+          missing=()
+          for name in MAC_CSC_LINK MAC_CSC_KEY_PASSWORD APPLE_API_KEY APPLE_API_KEY_ID APPLE_API_ISSUER; do
+            if [ -z "${!name}" ]; then
+              missing+=("$name")
+            fi
+          done
+
+          if [ "${#missing[@]}" -gt 0 ]; then
+            echo "has_secrets=false" >> "$GITHUB_OUTPUT"
+            echo "mode=adhoc" >> "$GITHUB_OUTPUT"
+            echo "::warning::Missing required macOS signing/notarization secrets: ${missing[*]}"
+            echo "Building ad-hoc signed macOS artifacts without notarization for direct testing."
+          else
+            echo "has_secrets=true" >> "$GITHUB_OUTPUT"
+            echo "mode=signed" >> "$GITHUB_OUTPUT"
+          fi
+
+      - name: Build Electron artifacts (Linux)
+        if: matrix.platform == 'linux'
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+        shell: bash
+        run: |
+          if [ "${{ matrix.arch }}" = "arm64" ]; then
+            export USE_SYSTEM_FPM=true
+          fi
+
+          npx electron-builder --linux --${{ matrix.arch }} --publish never
+
+      - name: Build Electron artifacts (macOS signed)
+        if: matrix.platform == 'macos' && steps.mac_secrets.outputs.has_secrets == 'true'
+        env:
+          CSC_LINK: ${{ secrets.MAC_CSC_LINK }}
+          CSC_KEY_PASSWORD: ${{ secrets.MAC_CSC_KEY_PASSWORD }}
+          APPLE_API_KEY: ${{ secrets.APPLE_API_KEY }}
+          APPLE_API_KEY_ID: ${{ secrets.APPLE_API_KEY_ID }}
+          APPLE_API_ISSUER: ${{ secrets.APPLE_API_ISSUER }}
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          DEBUG: electron-builder,electron-notarize*
+        run: npx electron-builder --mac --x64 --arm64 --publish never
+
+      - name: Build Electron artifacts (macOS ad-hoc)
+        if: matrix.platform == 'macos' && steps.mac_secrets.outputs.has_secrets != 'true'
+        env:
+          CSC_IDENTITY_AUTO_DISCOVERY: 'false'
+          MACOS_ADHOC_SIGN: '1'
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          DEBUG: electron-builder,electron-osx-sign*
+        run: npx electron-builder --mac --x64 --arm64 --publish never -c.mac.notarize=false -c.mac.sign=./scripts/adhoc-sign-mac.cjs
+
+      - name: Build Electron artifacts (Windows)
+        if: matrix.platform == 'windows'
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+        run: npx electron-builder --win --${{ matrix.arch }} --publish never
+
+      - name: Normalize Linux release artifact names
+        if: matrix.platform == 'linux'
+        shell: bash
+        run: |
+          set -euo pipefail
+          VERSION="$(node -p "require('./package.json').version")"
+          ARCH="${{ matrix.arch }}"
+
+          normalize_artifact() {
+            local source="$1"
+            local target="$2"
+
+            if [ "$source" = "$target" ] || [ ! -f "$source" ]; then
+              return
+            fi
+
+            if [ -f "$target" ]; then
+              echo "::error file=$target::Cannot normalize $source because the target already exists."
+              exit 1
+            fi
+
+            mv "$source" "$target"
+            echo "Renamed $(basename "$source") -> $(basename "$target")"
+          }
+
+          if [ "$ARCH" = "x64" ]; then
+            normalize_artifact \
+              "release/vk-bot-desktop-linux-x86_64-${VERSION}.AppImage" \
+              "release/vk-bot-desktop-linux-x64-${VERSION}.AppImage"
+            normalize_artifact \
+              "release/vk-bot-desktop-linux-amd64-${VERSION}.deb" \
+              "release/vk-bot-desktop-linux-x64-${VERSION}.deb"
+          elif [ "$ARCH" = "arm64" ]; then
+            normalize_artifact \
+              "release/vk-bot-desktop-linux-aarch64-${VERSION}.AppImage" \
+              "release/vk-bot-desktop-linux-arm64-${VERSION}.AppImage"
+            normalize_artifact \
+              "release/vk-bot-desktop-linux-aarch64-${VERSION}.deb" \
+              "release/vk-bot-desktop-linux-arm64-${VERSION}.deb"
+          fi
+
+          find release -maxdepth 1 -type f -printf '%f\n' | sort
+
+      - name: Smoke test Linux release artifacts
+        if: matrix.platform == 'linux'
+        shell: bash
+        run: |
+          set -euo pipefail
+          VERSION="$(node -p "require('./package.json').version")"
+          ARCH="${{ matrix.arch }}"
+
+          required_linux_artifacts=(
+            "release/vk-bot-desktop-linux-${ARCH}-${VERSION}.AppImage"
+            "release/vk-bot-desktop-linux-${ARCH}-${VERSION}.deb"
+            "release/vk-bot-desktop-linux-${ARCH}-${VERSION}.tar.gz"
+          )
+
+          for artifact in "${required_linux_artifacts[@]}"; do
+            if [ ! -f "$artifact" ]; then
+              echo "::error file=$artifact::Expected versioned Linux release artifact was not created."
+              ls -la release || true
+              exit 1
+            fi
+          done
+
+          debs=("release/vk-bot-desktop-linux-${ARCH}-${VERSION}.deb")
+          appimages=("release/vk-bot-desktop-linux-${ARCH}-${VERSION}.AppImage")
+          tarballs=("release/vk-bot-desktop-linux-${ARCH}-${VERSION}.tar.gz")
+
+          for deb in "${debs[@]}"; do
+            echo "Inspecting Debian package: $deb"
+            dpkg-deb --info "$deb"
+            dpkg-deb --contents "$deb" | tee "$RUNNER_TEMP/deb-contents.txt"
+            if ! grep -Eq '/(opt|usr)/(bin|lib|share)/' "$RUNNER_TEMP/deb-contents.txt"; then
+              echo "::error file=$deb::Debian package does not contain an installable app payload."
+              exit 1
+            fi
+          done
+
+          for appimage in "${appimages[@]}"; do
+            echo "Extracting AppImage payload: $appimage"
+            chmod +x "$appimage"
+            extract_dir="$(mktemp -d)"
+            artifact_path="$(realpath "$appimage")"
+            (cd "$extract_dir" && "$artifact_path" --appimage-extract >/dev/null)
+            test -d "$extract_dir/squashfs-root"
+            find "$extract_dir/squashfs-root" -maxdepth 4 -type f | sort > "$RUNNER_TEMP/appimage-contents.txt"
+            sed -n '1,100p' "$RUNNER_TEMP/appimage-contents.txt"
+            find "$extract_dir/squashfs-root" -maxdepth 4 -type f -name '*.desktop' -print -quit | grep -q .
+          done
+
+          for tarball in "${tarballs[@]}"; do
+            echo "Inspecting tarball: $tarball"
+            tar -tzf "$tarball" > "$RUNNER_TEMP/tarball-contents.txt"
+            sed -n '1,100p' "$RUNNER_TEMP/tarball-contents.txt"
+            grep -Eq 'VK Bot Desktop|vk-bot-desktop|resources/app' "$RUNNER_TEMP/tarball-contents.txt"
+          done
+
+      - name: Smoke test macOS release artifacts
+        if: matrix.platform == 'macos'
+        shell: bash
+        env:
+          MACOS_BUILD_MODE: ${{ steps.mac_secrets.outputs.mode }}
+        run: |
+          set -euo pipefail
+          shopt -s nullglob
+          VERSION="$(node -p "require('./package.json').version")"
+
+          dmgs=(
+            "release/vk-bot-desktop-macos-arm64-${VERSION}.dmg"
+            "release/vk-bot-desktop-macos-x64-${VERSION}.dmg"
+          )
+          zips=(
+            "release/vk-bot-desktop-macos-arm64-${VERSION}.zip"
+            "release/vk-bot-desktop-macos-x64-${VERSION}.zip"
+          )
+
+          for artifact in "${dmgs[@]}" "${zips[@]}"; do
+            if [ ! -f "$artifact" ]; then
+              echo "::error file=$artifact::Expected versioned macOS release artifact was not created."
+              ls -la release || true
+              exit 1
+            fi
+          done
+
+          for dmg in "${dmgs[@]}"; do
+            echo "Mounting DMG: $dmg"
+            mount_dir="$(mktemp -d)"
+            hdiutil attach "$dmg" -mountpoint "$mount_dir" -nobrowse -readonly
+            mounted_app="$mount_dir/VK Bot Desktop.app"
+            installed_app="$RUNNER_TEMP/VK Bot Desktop.app"
+
+            if [ ! -d "$mounted_app" ]; then
+              echo "::error file=$dmg::Mounted DMG does not contain VK Bot Desktop.app."
+              find "$mount_dir" -maxdepth 2 -print
+              hdiutil detach "$mount_dir"
+              exit 1
+            fi
+
+            rm -rf "$installed_app"
+            ditto "$mounted_app" "$installed_app"
+            hdiutil detach "$mount_dir"
+
+            app_info="$installed_app/Contents/Info.plist"
+            executable="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleExecutable' "$app_info")"
+            bundle_id="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleIdentifier' "$app_info")"
+
+            if [ "$bundle_id" != "team.deep.vk-bot-desktop" ]; then
+              echo "::error file=$dmg::Unexpected macOS app bundle identifier: $bundle_id"
+              exit 1
+            fi
+
+            if [ ! -x "$installed_app/Contents/MacOS/$executable" ]; then
+              echo "::error file=$dmg::Mounted app executable is missing or not executable."
+              find "$installed_app/Contents" -maxdepth 3 -print
+              exit 1
+            fi
+
+            codesign --verify --deep --strict --verbose=2 "$installed_app"
+
+            if [ "$MACOS_BUILD_MODE" = "signed" ]; then
+              spctl --assess --type execute --verbose=4 "$installed_app"
+              xcrun stapler validate "$installed_app"
+            else
+              codesign --display --verbose=2 "$installed_app" 2>&1 | tee "$RUNNER_TEMP/macos-codesign.txt"
+              if ! grep -Fq 'Signature=adhoc' "$RUNNER_TEMP/macos-codesign.txt"; then
+                echo "::error file=$dmg::Expected ad-hoc macOS signature for no-Apple-account build."
+                exit 1
+              fi
+            fi
+          done
+
+          for zip in "${zips[@]}"; do
+            echo "Testing ZIP archive: $zip"
+            unzip -t "$zip"
+            zip_dir="$(mktemp -d)"
+            ditto -x -k "$zip" "$zip_dir"
+            if ! find "$zip_dir" -maxdepth 2 -type d -name 'VK Bot Desktop.app' -print -quit | grep -q .; then
+              echo "::error file=$zip::ZIP archive does not contain VK Bot Desktop.app."
+              find "$zip_dir" -maxdepth 3 -print
+              exit 1
+            fi
+          done
+
+      - name: Smoke test Windows release artifacts
+        if: matrix.platform == 'windows'
+        shell: pwsh
+        run: |
+          $ErrorActionPreference = 'Stop'
+          $version = (Get-Content package.json | ConvertFrom-Json).version
+          $arch = '${{ matrix.arch }}'
+          $installerPath = "release/vk-bot-desktop-windows-installer-$arch-$version.exe"
+          $portablePath = "release/vk-bot-desktop-windows-portable-$arch-$version.exe"
+
+          if (!(Test-Path $installerPath) -or !(Test-Path $portablePath)) {
+            Get-ChildItem -Path release -File | Format-Table -AutoSize
+            throw "Expected versioned Windows installer and portable executables for $arch."
+          }
+
+          $installers = @(Get-Item $installerPath)
+          $portableApps = @(Get-Item $portablePath)
+
+          foreach ($installer in $installers) {
+            $installDir = Join-Path $env:RUNNER_TEMP 'vk-bot-desktop-install'
+            Remove-Item -Recurse -Force -ErrorAction SilentlyContinue $installDir
+            New-Item -ItemType Directory -Path $installDir | Out-Null
+
+            $process = Start-Process -FilePath $installer.FullName -ArgumentList @('/S', "/D=$installDir") -Wait -PassThru
+            if ($process.ExitCode -ne 0) {
+              throw "Installer failed with exit code $($process.ExitCode): $($installer.FullName)"
+            }
+
+            $installedExe = Join-Path $installDir 'VK Bot Desktop.exe'
+            if (!(Test-Path $installedExe)) {
+              Get-ChildItem -Recurse -Force $installDir | Format-Table -AutoSize
+              throw "Installed application executable not found at $installedExe"
+            }
+          }
+
+          foreach ($portable in $portableApps) {
+            if ($portable.Length -le 0) {
+              throw "Portable executable is empty: $($portable.FullName)"
+            }
+            Write-Host "Portable artifact: $($portable.Name) ($($portable.Length) bytes)"
+          }
+
+      - name: Compute SHA256 sums (Linux/macOS)
+        if: matrix.platform == 'linux' || matrix.platform == 'macos'
+        shell: bash
+        run: |
+          cd release
+          checksum_file="SHA256SUMS-${{ matrix.os }}.txt"
+          artifact_count=0
+          : > "$checksum_file"
+
+          while IFS= read -r file; do
+            artifact_count=$((artifact_count + 1))
+            shasum -a 256 "$file" | sed 's#  \./#  #' >> "$checksum_file"
+          done < <(
+            find . -maxdepth 1 -type f \
+              \( -name '*.AppImage' -o -name '*.deb' -o -name '*.tar.gz' \
+                 -o -name '*.dmg' -o -name '*.zip' \) \
+              | sort
+          )
+
+          if [ "$artifact_count" -eq 0 ]; then
+            echo "No Linux/macOS release artifacts were found to hash." >&2
+            exit 1
+          fi
+
+          cat "$checksum_file"
+
+      - name: Compute SHA256 sums (Windows)
+        if: matrix.platform == 'windows'
+        shell: pwsh
+        run: |
+          Set-Location release
+          $files = Get-ChildItem -File | Where-Object { $_.Name -match '\.(exe|msi)$' }
+          $entries = foreach ($file in $files) {
+            $hash = (Get-FileHash -Algorithm SHA256 $file.Name).Hash.ToLower()
+            "$hash  $($file.Name)"
+          }
+          $entries | Out-File -Encoding ascii -FilePath SHA256SUMS-${{ matrix.os }}.txt
+          Get-Content SHA256SUMS-${{ matrix.os }}.txt
+
+      - name: Write build provenance
+        shell: bash
+        env:
+          RELEASE_TAG: ${{ needs.desktop-release-context.outputs.release-tag }}
+          TARGET_SHA: ${{ needs.desktop-release-context.outputs.target-sha }}
+          MACOS_SIGNING_SECRETS_AVAILABLE: ${{ steps.mac_secrets.outputs.has_secrets }}
+          MACOS_BUILD_MODE: ${{ steps.mac_secrets.outputs.mode }}
+        run: |
+          mkdir -p release
+          {
+            echo "repository=${{ github.repository }}"
+            echo "workflow=${{ github.workflow }}"
+            echo "run_id=${{ github.run_id }}"
+            echo "run_attempt=${{ github.run_attempt }}"
+            echo "tag=$RELEASE_TAG"
+            echo "target_sha=$TARGET_SHA"
+            echo "builder_os=${{ matrix.os }}"
+            echo "builder_arch=${{ matrix.arch }}"
+            if [ "${{ matrix.platform }}" = "macos" ]; then
+              echo "macos_artifacts=$MACOS_BUILD_MODE"
+              if [ "$MACOS_SIGNING_SECRETS_AVAILABLE" = "true" ]; then
+                echo "macos_notarization=enabled"
+              else
+                echo "macos_notarization=skipped"
+                echo "macos_signature=ad-hoc"
+                echo "macos_skip_reason=missing signing/notarization secrets"
+              fi
+            fi
+          } > "release/provenance-${{ matrix.os }}.txt"
+
+      - name: Upload artifacts
+        uses: actions/upload-artifact@v4
+        with:
+          name: electron-${{ matrix.platform }}-${{ matrix.arch }}
+          path: |
+            release/*.AppImage
+            release/*.deb
+            release/*.tar.gz
+            release/*.dmg
+            release/*.zip
+            release/*.exe
+            release/*.msi
+            release/SHA256SUMS-*.txt
+            release/provenance-*.txt
+          if-no-files-found: ignore
+          retention-days: 7
+
+  desktop-publish:
+    name: Publish GitHub release
+    needs: [desktop-release-context, desktop-build]
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    if: |
+      always() &&
+      !cancelled() &&
+      needs.desktop-release-context.result == 'success' &&
+      needs.desktop-build.result == 'success' &&
+      needs.desktop-release-context.outputs.should-publish == 'true'
+    permissions:
+      contents: write
+      id-token: write
+      attestations: write
+    steps:
+      - uses: actions/checkout@v6
+        with:
+          ref: ${{ needs.desktop-release-context.outputs.target-sha }}
+
+      - name: Download all build artifacts
+        uses: actions/download-artifact@v4
+        with:
+          path: artifacts
+
+      - name: Aggregate SHA256SUMS
+        run: |
+          mkdir -p dist
+          find artifacts -type f -name 'SHA256SUMS-*.txt' -exec cat {} + | sort > dist/SHA256SUMS.txt
+          find artifacts -type f -name 'provenance-*.txt' -exec cat {} + > dist/BUILD-PROVENANCE.txt
+          find artifacts -type f \
+            \( -name '*.AppImage' -o -name '*.deb' -o -name '*.tar.gz' \
+               -o -name '*.dmg' -o -name '*.zip' \
+               -o -name '*.exe' -o -name '*.msi' \) \
+            -exec cp {} dist/ \;
+          ls -la dist
+          cat dist/SHA256SUMS.txt
+
+      - name: Validate versioned release asset names
+        run: node scripts/validate-release-assets.mjs --dist dist --tag "${{ needs.desktop-release-context.outputs.release-tag }}"
+
+      - name: Generate release artifact attestations
+        uses: actions/attest@v4
+        with:
+          subject-path: dist/*
+
+      - name: Create or update GitHub release
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          TAG: ${{ needs.desktop-release-context.outputs.release-tag }}
+          TARGET_SHA: ${{ needs.desktop-release-context.outputs.target-sha }}
+        run: |
+          if ! gh release view "$TAG" >/dev/null 2>&1; then
+            gh release create "$TAG" \
+              --target "$TARGET_SHA" \
+              --title "$TAG" \
+              --notes "Cross-platform Electron build of vk-bot-desktop. Filenames include the app version. Verify downloads against SHA256SUMS.txt, BUILD-PROVENANCE.txt, and GitHub artifact attestations."
+          fi
+          gh release upload "$TAG" dist/* --clobber
+
+      - name: Verify published release asset links
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          TAG: ${{ needs.desktop-release-context.outputs.release-tag }}
+        run: |
+          set -euo pipefail
+
+          gh release view "$TAG" --json assets --jq '.assets[].name' | sort > release-assets.txt
+          find dist -maxdepth 1 -type f -printf '%f\n' | sort > dist-assets.txt
+
+          while IFS= read -r asset; do
+            if ! grep -Fxq "$asset" release-assets.txt; then
+              echo "::error file=dist/$asset::Uploaded release asset is missing from GitHub release metadata."
+              cat release-assets.txt
+              exit 1
+            fi
+
+            url="https://github.com/${GITHUB_REPOSITORY}/releases/download/${TAG}/${asset}"
+            status="$(
+              curl \
+                --fail \
+                --location \
+                --silent \
+                --show-error \
+                --retry 10 \
+                --retry-all-errors \
+                --retry-delay 5 \
+                --range 0-0 \
+                --output /dev/null \
+                --write-out '%{http_code}' \
+                "$url" || true
+            )"
+
+            if [ "$status" != "200" ] && [ "$status" != "206" ]; then
+              echo "::error file=dist/$asset::Published release asset URL returned HTTP $status."
+              echo "$url"
+              exit 1
+            fi
+          done < dist-assets.txt
